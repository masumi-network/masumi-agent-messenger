SPACETIMEDB_DB_NAME=agentmessenger-dev
SPACETIMEDB_HOST=https://maincloud.spacetimedb.com
VITE_SPACETIMEDB_DB_NAME=agentmessenger-dev
VITE_SPACETIMEDB_HOST=https://maincloud.spacetimedb.com
NEXT_PUBLIC_SPACETIMEDB_DB_NAME=agentmessenger-dev
NEXT_PUBLIC_SPACETIMEDB_HOST=https://maincloud.spacetimedb.com
REACT_APP_SPACETIMEDB_DB_NAME=agentmessenger-dev
REACT_APP_SPACETIMEDB_HOST=https://maincloud.spacetimedb.com
EXPO_PUBLIC_SPACETIMEDB_DB_NAME=agentmessenger-dev
EXPO_PUBLIC_SPACETIMEDB_HOST=https://maincloud.spacetimedb.com
PUBLIC_SPACETIMEDB_DB_NAME=agentmessenger-dev
PUBLIC_SPACETIMEDB_HOST=https://maincloud.spacetimedb.com
MASUMI_NETWORK=Preprod

# Shared OIDC issuer for the webapp, CLI, and Spacetime publish/generate flow.
MASUMI_OIDC_ISSUER=https://masumi-saas-dev-exyyd.ondigitalocean.app
#MASUMI_OIDC_ISSUER=http://localhost:2999

# Webapp local browser auth.
#MASUMI_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
#MASUMI_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/
MASUMI_SESSION_SECRET=replace-this-for-local-dev

# Local SpacetimeDB for dev.
#VITE_SPACETIMEDB_HOST=ws://localhost:3000
#VITE_SPACETIMEDB_DB_NAME=agentmessenger-dev
#SPACETIMEDB_HOST=ws://localhost:3000
#SPACETIMEDB_DB_NAME=agentmessenger-dev

# Webapp OAuth client id (browser / authorization-code flow).
MASUMI_OIDC_CLIENT_ID=masumi-spacetime-web

# CLI OAuth client id (device-code flow).
MASUMI_CLI_OIDC_CLIENT_ID=masumi-spacetime-cli

MASUMI_OIDC_AUDIENCES=masumi-spacetime-web,masumi-spacetime-cli
