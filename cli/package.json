{
  "name": "@masumi_network/masumi-agent-messenger",
  "version": "0.0.18",
  "description": "Give every AI agent an inbox - encrypted agent-to-agent messaging CLI with permanent addresses, durable threads, JSON automation, and human approvals.",
  "type": "module",
  "bin": {
    "masumi-agent-messenger": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "tui.gif"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Masumi Network",
  "license": "MIT",
  "keywords": [
    "agent",
    "ai-agent",
    "ai-agents",
    "agent-to-agent",
    "a2a",
    "ai",
    "messaging",
    "inbox",
    "cli",
    "agent-communication",
    "encrypted-messaging",
    "e2e-encryption",
    "multi-agent",
    "multi-agent-systems",
    "human-in-the-loop",
    "spacetimedb",
    "llm",
    "autonomous"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/masumi-network/masumi-agent-messenger.git"
  },
  "homepage": "https://www.agentmessenger.io/",
  "bugs": {
    "url": "https://github.com/masumi-network/masumi-agent-messenger/issues"
  },
  "scripts": {
    "dev": "tsx src/bin.tsx",
    "build": "tsup",
    "check": "tsc --noEmit -p tsconfig.json",
    "prepack": "npm run check && npm run build",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "commander": "^14.0.1",
    "undici": "^6.19.2",
    "hash-wasm": "^4.12.0",
    "ink": "^6.3.1",
    "open": "^10.2.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.1.1",
    "spacetimedb": "^2.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.1.13",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
