# Copy this file to `.env` or `.env.local` to override local defaults.
# The CLI auto-loads `.env` and `.env.local` before resolving auth config.
# Its default SpacetimeDB target comes from shared/generated-oidc-config.*.
# The webapp server and Spacetime publish/generate scripts read the same root env files too.

# Configure the shared OIDC issuer and audience list for staging/production-like setups.
MASUMI_OIDC_ISSUER=https://masumi-saas-dev-exyyd.ondigitalocean.app
MASUMI_OIDC_AUDIENCES=masumi-spacetime-web,masumi-spacetime-cli

# Webapp OAuth client id (browser / authorization-code flow).
MASUMI_OIDC_CLIENT_ID=masumi-spacetime-web

# CLI OAuth client id (device-code flow).
# Must be a public client with device-code grant enabled on the OIDC server.
# If unset, the CLI uses the built-in default `masumi-spacetime-cli`.
# It does not inherit MASUMI_OIDC_CLIENT_ID because the browser client cannot
# sign in through the device-code flow.
MASUMI_CLI_OIDC_CLIENT_ID=masumi-spacetime-cli

# For isolated local development only, you can opt into the generated local defaults instead
# of setting the values above.
# MASUMI_ALLOW_DEFAULT_LOCAL_OIDC_CONFIG=true

# Optional: local Masumi OIDC
# MASUMI_OIDC_ISSUER=http://localhost:2999
# MASUMI_OIDC_CLIENT_ID=masumi-spacetime-web
# MASUMI_CLI_OIDC_CLIENT_ID=masumi-spacetime-cli
# MASUMI_OIDC_AUDIENCES=masumi-spacetime-web,masumi-spacetime-cli

# Optional webapp-only OIDC settings for local browser auth.
# MASUMI_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
# MASUMI_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/
# MASUMI_SESSION_SECRET=replace-this-for-local-dev

# Re-run `pnpm run spacetime:prepare-env` after changing the issuer, client id,
# audiences, Masumi network, or SpacetimeDB target.

SPACETIMEDB_HOST=ws://localhost:3000
SPACETIMEDB_DB_NAME=agentmessenger-dev
VITE_SPACETIMEDB_HOST=ws://localhost:3000
VITE_SPACETIMEDB_DB_NAME=agentmessenger-dev

# Optional: show this discoverable public channel on the signed-out root page.
# The webapp also accepts PUBLIC_CHANNEL_ID for deploy targets that use PUBLIC_* envs.
# VITE_PUBLIC_CHANNEL_ID=1

# Maincloud alternative:
# SPACETIMEDB_HOST=wss://maincloud.spacetimedb.com
# VITE_SPACETIMEDB_HOST=wss://maincloud.spacetimedb.com

# Optional: add extra OIDC scopes beyond the built-in Masumi defaults.
# MASUMI_OIDC_SCOPES=

# Masumi network for registration, lookups, and all SaaS interactions.
# Accepted values: Preprod, Mainnet (case-insensitive). Defaults to Preprod.
MASUMI_NETWORK=Preprod
